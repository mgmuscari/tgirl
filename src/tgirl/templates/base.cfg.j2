// tgirl grammar - auto-generated, do not edit
// Lark EBNF format for Outlines CFGGuide

{% if tool_alternatives %}
?start: expr | insufficient
expr: tool_call | composition
tool_call: {{ tool_alternatives }}
{% else %}
?start: insufficient | composition
expr: composition
{% endif %}

insufficient: "(" "insufficient-resources" SPACE reason ")"
reason: "\"quota-exhausted\"" | "\"cost-exceeded\"" | "\"scope-denied\"" | "\"type-mismatch\"" | "\"no-valid-plan\""

SPACE: " "

