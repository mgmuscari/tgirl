// Composition operators
composition: threading | let_expr | if_expr | try_expr | pmap_expr

SYMBOL: /[a-zA-Z_][a-zA-Z0-9_-]*/

threading: "(" "->" SPACE expr (SPACE expr)+ ")"
let_expr: "(" "let" SPACE "[" binding (SPACE binding)* "]" SPACE expr ")"
binding: SYMBOL SPACE expr
if_expr: "(" "if" SPACE expr SPACE expr SPACE expr ")"
try_expr: "(" "try" SPACE expr SPACE "(" "catch" SPACE SYMBOL SPACE expr ")" ")"
pmap_expr: "(" "pmap" SPACE "[" expr (SPACE expr)* "]" SPACE expr ")"
