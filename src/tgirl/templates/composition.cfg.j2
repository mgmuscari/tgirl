// Composition operators
composition: threading | let_expr | if_expr | try_expr | pmap_expr

SYMBOL: /[a-zA-Z_][a-zA-Z0-9_-]*/

threading: "(" "->" " " expr (" " expr)+ ")"
let_expr: "(" "let" " " "[" binding (" " binding)* "]" " " expr ")"
binding: SYMBOL " " expr
if_expr: "(" "if" " " expr " " expr " " expr ")"
try_expr: "(" "try" " " expr " " "(" "catch" " " SYMBOL " " expr ")" ")"
pmap_expr: "(" "pmap" " " "[" expr (" " expr)* "]" " " expr ")"
